# ── AI Provider Configuration ─────────────────────────────────────────────────
# Options: "ollama" | "gemma_api"
AI_PROVIDER=gemma_api

# Ollama Settings (Development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_MAX_TOKENS=8192

# Gemma API Settings (Production)
GEMMA_API_KEY=your_google_ai_studio_key_here
GEMMA_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMMA_API_MODEL=gemma-2-27b-it
GEMMA_API_TIMEOUT_SECONDS=120

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./pravaah.db

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=PRAVAAH
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Cache TTL (seconds) ───────────────────────────────────────────────────────
WEATHER_CACHE_TTL_SECONDS=3600
RIVER_CACHE_TTL_SECONDS=1800
HISTORICAL_CACHE_TTL_SECONDS=86400

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Data Paths ────────────────────────────────────────────────────────────────
GEOJSON_PATH=data/geojson/west_bengal_districts.geojson
HISTORICAL_DATA_PATH=data/historical/wb_flood_history.json
RIVER_STATIONS_PATH=data/static/river_gauge_stations.json
