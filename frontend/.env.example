# API Connection URL (defaults to http://localhost:8000 if omitted)
VITE_API_URL=http://localhost:8000

# Google OAuth Client ID
# Obtain this from Google Cloud Console (https://console.cloud.google.com)
# Create a Web Application OAuth Client ID, add "http://localhost:5173" to Authorized JavaScript Origins
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
